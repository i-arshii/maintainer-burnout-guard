# ---------------------------------------------------------------------------
# Maintainer Burnout Guard — SSM Parameter Reference
# ---------------------------------------------------------------------------
# The Lambda reads ALL config from AWS SSM Parameter Store at runtime.
# This file documents the required parameters for local reference only.
#
# Provision with:
#   aws ssm put-parameter --name "/burnout-guard/github-token" \
#       --value "ghp_xxx" --type SecureString
#
#   aws ssm put-parameter --name "/burnout-guard/repos" \
#       --value "owner/repo1,owner/repo2" --type String
# ---------------------------------------------------------------------------

# /burnout-guard/github-token   (SecureString)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# /burnout-guard/repos          (String — comma-separated)
REPOS=owner/repo1,owner/repo2

# /burnout-guard/ses-from       (String — must be SES-verified)
SES_FROM=guard@yourdomain.com

# /burnout-guard/ses-to         (String)
SES_TO=you@yourdomain.com

# /burnout-guard/lookback-hours (String — default 24)
LOOKBACK_HOURS=24

# /burnout-guard/bedrock-model-id (String)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
